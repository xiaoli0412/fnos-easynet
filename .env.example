# ─────────────────────────────────────────────────────────
# fnos-easynet Environment Variables
# Copy this file to .env and modify as needed
# ─────────────────────────────────────────────────────────

# Management server port (Web UI)
SERVER_PORT=9090

# mihomo API address (internal)
MIHOMO_API=http://127.0.0.1:9097

# Configuration directory
CONFIG_DIR=/etc/mihomo

# Data directory (subscriptions, etc.)
DATA_DIR=/data

# Timezone
TZ=Asia/Shanghai
